<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscador preferido"
            android:textColor="@color/theme_on_surface"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioSearchEngine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <RadioButton android:id="@+id/rbGoogle" android:text="Google"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbBing" android:text="Bing"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbDuck" android:text="DuckDuckGo"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbStartpage" android:text="Startpage"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbAll" android:text="Todos (abre pestañas comparando resultados)"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bloqueador de anuncios y trackers"
                android:textColor="@color/theme_on_surface"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <Switch
                android:id="@+id/switchAdblock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paleta de color"
            android:textColor="@color/theme_on_surface"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/paletteRow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <!-- swatches se agregan por código -->
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Animaciones"
                android:textColor="@color/theme_on_surface"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <Switch
                android:id="@+id/switchAnimations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Idioma del traductor"
            android:textColor="@color/theme_on_surface"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioLang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton android:id="@+id/rbEs" android:text="Español"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbEn" android:text="Inglés"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
            <RadioButton android:id="@+id/rbPt" android:text="Portugués"
                android:textColor="@color/theme_on_surface" android:buttonTint="@color/theme_accent"/>
        </RadioGroup>

    </LinearLayout>
</ScrollView>
