<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background">

    <!-- Barra superior: retro, adelante, buscador, escudo, tabs, menu -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_toolbar_gradient"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Atrás" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_forward"
            android:contentDescription="Adelante" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_bar"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/iconAdblock"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_shield"
                    android:alpha="0.85"/>

                <EditText
                    android:id="@+id/searchBar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:textColorHint="#8FB3B0"
                    android:textColor="@color/theme_on_surface"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:textSize="15sp"/>
            </LinearLayout>
        </FrameLayout>

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_refresh"
            android:contentDescription="Recargar" />

        <ImageButton
            android:id="@+id/btnTabs"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_tabs"
            android:contentDescription="Pestañas" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            android:contentDescription="Menú" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:max="100"
        android:progressDrawable="@drawable/bg_progress"
        android:visibility="gone"/>

    <!-- Contenedor donde se inflan los WebViews de cada pestaña -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="59dp"/>

    <!-- Panel lateral de pestañas (oculto por defecto, animado al abrir) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tabRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="59dp"
        android:background="@color/theme_background"
        android:visibility="gone"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <ImageButton
        android:id="@+id/btnNewTabFab"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/bg_tab_card"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        android:elevation="8dp"/>

    <!-- Panel flotante de traducción -->
    <LinearLayout
        android:id="@+id/translatePanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_tab_card"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="10dp">

        <TextView
            android:id="@+id/translateStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Traduciendo página..."
            android:textColor="@color/theme_on_surface"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
