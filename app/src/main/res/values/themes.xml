<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NovaBrowser" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/theme_primary</item>
        <item name="colorPrimaryDark">@color/theme_primary_dark</item>
        <item name="colorAccent">@color/theme_accent</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:statusBarColor">@color/theme_toolbar</item>
        <item name="android:navigationBarColor">@color/theme_toolbar</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <style name="Theme.NovaBrowser.Splash" parent="Theme.NovaBrowser">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
